# --- Xcode 16 objectVersion 70 compatibility shim ------------------------------------
# Xcode 16 stamps `objectVersion = 70` in the project, but the bundled CocoaPods `xcodeproj`
# gem's compatibility table jumps 63 -> 77 (it has no 70). When CocoaPods creates the Pods
# project it copies the app project's object version (Integer 70) and Xcodeproj::Project#new
# looks it up, aborting `pod install` with:
#   "Unable to find compatibility version string for object version `70`".
# Teach xcodeproj that 70 == Xcode 16.0 (the table is frozen, so swap the constant). Runs
# before the Pods project is generated, locally and in Xcode Cloud; a no-op once the gem
# ships the mapping. Tracking: github.com/CocoaPods/CocoaPods/issues/12840
require 'xcodeproj'
unless Xcodeproj::Constants::COMPATIBILITY_VERSION_BY_OBJECT_VERSION.key?(70)
  _patched = Xcodeproj::Constants::COMPATIBILITY_VERSION_BY_OBJECT_VERSION.merge(70 => 'Xcode 16.0').freeze
  Xcodeproj::Constants.send(:remove_const, :COMPATIBILITY_VERSION_BY_OBJECT_VERSION)
  Xcodeproj::Constants.const_set(:COMPATIBILITY_VERSION_BY_OBJECT_VERSION, _patched)
end

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# VisionCamera is used for reaction recording ONLY — never geotagging. By default
# (v4) it compiles in its CLLocation APIs, which makes the binary reference location
# and forces a location purpose string (ITMS-90683) we don't want. Disabling it
# compiles that code out entirely, so no NSLocationWhenInUseUsageDescription is needed.
$VCEnableLocation = false

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Vidrip' do
  config = use_native_modules!

  # Firebase 24 Swift pods need modular headers to link as static libs.
  pod 'GoogleUtilities', :modular_headers => true
  pod 'FirebaseCoreInternal', :modular_headers => true
  pod 'FirebaseCore', :modular_headers => true
  pod 'FirebaseCoreExtension', :modular_headers => true
  pod 'FirebaseInstallations', :modular_headers => true
  pod 'FirebaseMessaging', :modular_headers => true
  pod 'GoogleDataTransport', :modular_headers => true
  pod 'nanopb', :modular_headers => true

  # MediaPipe Face Landmarker — powers the AR face-lens frame processor.
  pod 'MediaPipeTasksVision'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'VidripTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
