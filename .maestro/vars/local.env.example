# Copy to local.env and fill in. local.env is gitignored (never commit real creds).
# Pass to Maestro with:  maestro test .maestro --env-file .maestro/vars/local.env
#
# ── App under test ──────────────────────────────────────────────────────────
# Android: com.vidrip   iOS: com.isphillips.vidrip
APP_ID=com.vidrip

# ── Seeded test accounts (P7) ───────────────────────────────────────────────
# E2E signs in with PASSWORD auth (not magic link) so it can run headlessly.
# Each account must already exist in the prod/staging Supabase project AND have a
# password set (Account > Password Login). Magic-link-only accounts won't work.
#   A = primary (the device-under-test user)
#   B = friend  (A and B are mutual friends; B shares videos to A)
#   C = creator (owns a channel with posts + a members-only channel)
TEST_EMAIL_A=qa-primary@vidrip.test
TEST_PASSWORD_A=
TEST_HANDLE_A=qa_primary

TEST_EMAIL_B=qa-friend@vidrip.test
TEST_PASSWORD_B=
TEST_HANDLE_B=qa_friend

TEST_EMAIL_C=qa-creator@vidrip.test
TEST_PASSWORD_C=
TEST_HANDLE_C=qa_creator

# ── Seeded content fixtures (P7) ────────────────────────────────────────────
# Names/handles the flows look for. Match these to whatever QA actually seeds.
SEED_CHANNEL_NAME=QA Creator Channel
SEED_MEMBERS_ONLY_CHANNEL=QA Members Only
SEED_GROUP_CHAT_NAME=QA Group
SEED_EXCLUSIVE_COLLECTION=QA Exclusive

# A short public short/reel URL used by the Browse → share and reaction flows.
SEED_SHARE_URL=https://www.youtube.com/shorts/

# ── Invite code (A3) ────────────────────────────────────────────────────────
SEED_VALID_INVITE_CODE=
SEED_USED_INVITE_CODE=
