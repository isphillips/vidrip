diff --git a/node_modules/react-native-vision-camera/ios/Core/CameraSession+Audio.swift b/node_modules/react-native-vision-camera/ios/Core/CameraSession+Audio.swift
index 3d67c8c..ef9ff05 100644
--- a/node_modules/react-native-vision-camera/ios/Core/CameraSession+Audio.swift
+++ b/node_modules/react-native-vision-camera/ios/Core/CameraSession+Audio.swift
@@ -22,9 +22,19 @@ extension CameraSession {
     do {
       let audioSession = AVAudioSession.sharedInstance()
 
+      // Record through the Bluetooth headset mic (HFP) when AirPods/BT headphones are connected.
+      // iOS deliberately runs the BUILT-IN mic at very low sensitivity whenever a Bluetooth OUTPUT
+      // (A2DP) is active — and input gain is not settable (gainSettable=no) — so capturing from the
+      // built-in mic yielded a correct route but an almost inaudible voice. .allowBluetooth lets iOS
+      // use the headset's OWN mic (HFP), which records the wearer's voice at a normal level.
+      // Trade-off: while recording, the session is mono/narrowband (HFP), so the reel monitored in the
+      // ears is call-quality — but the EXPORTED video's source audio comes from the original file, so
+      // the final result is unaffected. With no Bluetooth device connected this changes nothing
+      // (built-in mic + speaker, exactly as before).
       try audioSession.updateCategory(AVAudioSession.Category.playAndRecord,
                                       mode: .videoRecording,
                                       options: [.mixWithOthers,
+                                                .allowBluetooth,
                                                 .allowBluetoothA2DP,
                                                 .defaultToSpeaker,
                                                 .allowAirPlay])
